APP_NAME="Product API"
APP_ENV=local
# O APP_KEY deve ficar vazio. O avaliador vai gerar o dele com `php artisan key:generate`
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
APP_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single

# Configurações do Banco de Dados (Docker - PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=products_api
DB_USERNAME=postgres
DB_PASSWORD=secret

# Configurações de Cache (Docker - Redis)
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Gerador de Documentação da API
SCRIBE_GENERATE_ALWAYS=true